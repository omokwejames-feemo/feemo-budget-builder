# Feemo Budget Manager — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Gmail account used to send verification codes to beta testers.
# Use an App Password (not your account password):
#   myaccount.google.com → Security → 2-Step Verification → App Passwords
EMAIL_USER=yourapp@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=Feemovision <yourapp@gmail.com>

VITE_FIREBASE_API_KEY=REPLACE_WITH_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=feemo-beta-functions.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=feemo-beta-functions
VITE_FIREBASE_STORAGE_BUCKET=feemo-beta-functions.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_WITH_APP_ID
