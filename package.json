{
  "name": "feemo-budget-manager",
  "version": "1.6.0",
  "description": "Feemo Budget Manager — Smart Production Budget Generator",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:vite": "vite --port 5173",
    "dev": "vite",
    "build:vite": "vite build",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "Feemovision",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "googleapis": "^171.4.0",
    "nodemailer": "^8.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "dotenv": "^17.4.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.feemovision.budget-manager",
    "productName": "Feemo Budget Manager",
    "asar": true,
    "artifactName": "Feemo-Budget-Manager-${version}-${arch}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "omokwejames-feemo",
      "repo": "feemo-budget-builder"
    },
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "feemo",
        "name": "Feemo Project",
        "description": "Feemo Budget Manager Project",
        "role": "Editor"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "public/icon-1024.png",
      "artifactName": "Feemo-Budget-Manager-Setup-${version}.${ext}",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
